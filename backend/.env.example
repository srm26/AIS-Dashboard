# Azure Service Principal credentials
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Comma-separated list of subscription IDs to monitor
AZURE_SUBSCRIPTION_IDS=sub-id-1,sub-id-2

# Optional: comma-separated resource group names to filter (leave empty for all)
AZURE_RESOURCE_GROUPS=

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS origin for frontend (change in production)
FRONTEND_ORIGIN=http://localhost:3000
