# Azure Service Principal credentials
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Comma-separated list of subscription IDs to monitor
AZURE_SUBSCRIPTION_IDS=sub-id-1,sub-id-2

# Optional: per-subscription SPN overrides (JSON, single line).
# Any subscription listed here uses its own SPN instead of the global credentials above.
# Subscriptions NOT listed fall back to AZURE_TENANT_ID / CLIENT_ID / CLIENT_SECRET.
# AZURE_SPNS=[{"subscription_id":"sub-id-1","tenant_id":"t1","client_id":"c1","client_secret":"s1"},{"subscription_id":"sub-id-2","tenant_id":"t2","client_id":"c2","client_secret":"s2"}]
AZURE_SPNS=[]

# Optional: comma-separated resource group names to filter (leave empty for all)
AZURE_RESOURCE_GROUPS=

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS origin for frontend (change in production)
FRONTEND_ORIGIN=http://localhost:3000

# Auth — set a long random string as the JWT signing secret
AUTH_SECRET_KEY=change-me-to-a-long-random-secret

# Users — comma-separated entries: username:password:role
# Roles: admin (can resubmit/enable/disable), viewer (read-only)
AUTH_USERS=alice:adminpassword:admin,bob:viewerpassword:viewer
